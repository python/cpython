#!/bin/sh
#
# This runs the Python-based configure.py script.
# Or, if python3 doesn't exist, runs configure.awk.

SCRIPT_DIR="$(dirname "$0")"

if test -n "${PYTHON_FOR_CONFIGURE:-}"; then
    echo "Using configure.py..."
    export PYTHONPATH=$SCRIPT_DIR/Tools/configure
    exec "$PYTHON_FOR_CONFIGURE" "$SCRIPT_DIR/Tools/configure/configure.py" --srcdir="$SCRIPT_DIR" "$@"
else
    echo "Using configure.awk..."
    exec "$SCRIPT_DIR/Tools/configure/configure.awk" --srcdir="$SCRIPT_DIR" "$@"
fi
