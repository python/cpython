#!/bin/sh
#
# This runs the Python-based configure.py script.
# Or, if python3 doesn't exist, runs configure-new.

SCRIPT_DIR="$(dirname "$0")"

# Check for python3 by trying to run it
if python3 -c '' >/dev/null 2>&1; then
    echo "Using configure.py..."
    export PYTHONPATH=$SCRIPT_DIR/Tools/configure
    python3 "$SCRIPT_DIR/Tools/configure/configure.py" --srcdir="$SCRIPT_DIR" "$@"
else
    echo "Using AWK/sh configure-new..."
    "$SCRIPT_DIR/configure-new" "$@"
fi
