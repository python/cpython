# Run: /bin/sh configure [options]

_tmpf=$(mktemp "${TMPDIR:-/tmp}/configure.XXXXXXXXXX") || exit 1
trap 'rm -f "$_tmpf"' EXIT
sed '1,/^#---AWK-START---$/d' "$0" > "$_tmpf"
exec awk -f "$_tmpf" -- "$@"
