	pyconf_arg_enable("experimental_jit", "no", "build the experimental just-in-time compiler (default is no)", "no|yes|yes-off|interpreter", "", "")
	pyconf_arg_with("address_sanitizer", "no", "enable AddressSanitizer memory error detector, 'asan' (default is no)", "", "", "no")
